# Frontend Environment Variables

# API URL Configuration
# Local development: http://localhost:5001
# Production (Render): https://travelo-r0d0.onrender.com
VITE_API_URL=

# Uncomment for local development:
# VITE_API_URL=http://localhost:5001

# For production, leave empty (frontend and backend on same domain)
# Since your backend serves the frontend, no need to set this in production